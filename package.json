{
  "name": "la-mosaique",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . && npm run typecheck",
    "lint:staged": "eslint $(git diff --cached --name-only --diff-filter=ACM \"*.ts\" \"*.tsx\" | sed 's| |\\\\ |g')",
    "prettier": "prettier --write **/*.{ts,tsx}",
    "prettier:staged": "prettier --write $(git diff --cached --name-only --diff-filter=ACM \"*.ts\" \"*.tsx\" | sed 's| |\\\\ |g')",
    "typecheck": "node node_modules/typescript/lib/tsc.js --noEmit"
  },
  "dependencies": {
    "firebase": "^11.0.0",
    "next": "^16.0.7",
    "prettier": "^3.7.4",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "swiper": "^12.0.3"
  },
  "devDependencies": {
    "typescript": "^5.9.3",
    "@types/node": "^24",
    "@types/react": "^18.3.27",
    "@types/react-dom": "^18.3.7",
    "postcss": "^8.5.6",
    "tailwindcss": "^3.4.18",
    "eslint": "^9.0.0",
    "eslint-config-next": "^16.0.7"
  }
}
